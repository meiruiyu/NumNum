# ---------------------------------------------------------------------------
# .env.example
# Copy this file to `.env` in the same directory and fill in your real values.
# `.env` is git-ignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# Yelp Fusion API key — used by the backend to power restaurant search/detail.
#   Get yours at: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=paste-your-yelp-fusion-api-key-here

# Groq API key — used by the backend chatbot route (POST /api/chat).
#   Get yours at: https://console.groq.com/keys
#   Free tier — no credit card required, 30 req/min.
GROQ_API_KEY=paste-your-groq-api-key-here

# Optional: pin a specific Groq model. Default = llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile

PORT=4000
